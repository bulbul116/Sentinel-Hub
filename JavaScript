// Using the Bitget Client (bgc) & Skills logic
import { BitgetWalletSkill } from '@bitget/agent-hub';

const agent = new BitgetWalletSkill({
  apiKey: process.env.BITGET_API_KEY,
  networks: ['BTC', 'ETH', 'SOL'] // Tracking your 3 core chains
});

async function smartSwapGuide(tokenIn, tokenOut, amount) {
  // 1. THINK: Check Portfolio & Price
  const portfolio = await agent.run('Balance + Price');
  
  // 2. THINK: Security Audit (Honeypot/Contract check)
  const security = await agent.run('Security Audit', { token: tokenOut });
  
  if (security.is_risky) {
    return "🛑 STOP: This token contract has high-risk permissions. Swap not advised.";
  }

  // 3. THINK: Find the best experience (Low fee + High Liquidity)
  const bestRoute = await agent.run('Swap Quote', {
    from: tokenIn, 
    to: tokenOut, 
    amount: amount,
    chains: ['EVM', 'SOLANA'] // It checks which chain offers the better deal
  });

  return {
    advice: `Found 0.4% better liquidity on ${bestRoute.chain}.`,
    action: bestRoute.calldata, // Ready to be signed by your wallet
    comparison: portfolio
  };
}
